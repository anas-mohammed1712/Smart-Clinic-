@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartClinic Management System</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts & Lucide Icons via CDN -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #fafbfc;
            color: #1e293b;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        .navbar {
            backdrop-filter: blur(10px);
            background-color: rgba(255, 255, 255, 0.9) !important;
            border-b: 1px solid #f1f5f9;
        }
        .btn-teal {
            background-color: #0d9488;
            color: #ffffff;
            border-radius: 12px;
            font-weight: 600;
            padding: 10px 24px;
            border: none;
            transition: all 0.2s ease;
        }
        .btn-teal:hover {
            background-color: #0f766e;
            transform: scale(1.02);
            color: #ffffff;
        }
        .footer {
            background-color: #0f172a;
            color: #94a3b8;
            padding: 60px 0 30px;
            border-top: 1px solid #1e293b;
        }
    </style>
</head>
<body class="d-flex flex-col h-100">

    <header>
        <nav class="navbar navbar-expand-md navbar-light bg-white border-bottom fixed-top shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" href="@Url.Action("Index", "Home")">
                    <div class="bg-teal text-white p-2 rounded-3 d-flex align-items-center justify-content-center" style="background-color: #0d9488; width: 40px; height: 40px;">
                        <i class="bi bi-heart-pulse-fill fs-5"></i>
                    </div>
                    <div>
                        <span class="d-block fw-bold text-dark lh-1" style="font-size: 20px;">SmartClinic</span>
                        <span class="text-uppercase fw-semibold" style="font-size: 9px; color: #0d9488; tracking-widest;">Management</span>
                    </div>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0 ms-md-4 gap-2">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium" href="@Url.Action("Index", "Home")">Home</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        @{
                            var userName = HttpContextAccessor.HttpContext?.Session.GetString("UserFullName");
                            var userRole = HttpContextAccessor.HttpContext?.Session.GetString("UserRole");
                        }
                        @if (!string.IsNullOrEmpty(userName))
                        {
                            <div class="dropdown">
                                <a href="#" class="d-flex align-items-center gap-2 text-decoration-none dropdown-toggle text-dark" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="bg-light border text-teal border-teal-subtle rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px; color: #0d9488;">
                                        @userName.Substring(0, 1)
                                    </div>
                                    <div class="text-start d-none d-lg-block">
                                        <span class="d-block fw-semibold lh-1" style="font-size: 13px;">@userName</span>
                                        <span class="text-uppercase fw-bold text-teal" style="font-size: 9px; color: #0d9488;">@userRole</span>
                                    </div>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2 rounded-3" aria-labelledby="userMenuDropdown">
                                    <li>
                                        <a class="dropdown-item rounded-2 py-2 text-dark font-medium" href="@Url.Action("Dashboard", "Account")">
                                            <i class="bi bi-grid-fill me-2 text-teal"></i>Dashboard
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item rounded-2 py-2 text-danger" href="@Url.Action("SignOut", "Account")">
                                            <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="@Url.Action("Login", "Account")" class="btn btn-link text-decoration-none fw-semibold text-dark">Log In</a>
                            <a href="@Url.Action("Register", "Account")" class="btn btn-teal">Sign Up</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-shrink-0" style="margin-top: 100px; padding-bottom: 60px;">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="footer mt-auto">
        <div class="container text-start">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="bg-teal text-white p-2 rounded-3 d-flex align-items-center justify-content-center" style="background-color: #0d9488; width: 35px; height: 35px;">
                            <i class="bi bi-heart-pulse-fill fs-6"></i>
                        </div>
                        <span class="fw-bold text-white fs-5 lh-1">SmartClinic</span>
                    </div>
                    <p class="text-slate-400" style="font-size: 14px; max-width: 320px;">
                        Delivering high-precision healthcare services powered by intelligent medical coordinators and role-based specialists.
                    </p>
                </div>
                <div class="col-md-4">
                    <h5 class="text-uppercase fw-bold text-teal mb-3" style="font-size: 12px; color: #2dd4bf; letter-spacing: 1px;">Clinic Departments</h5>
                    <ul class="list-unstyled d-flex flex-column gap-2" style="font-size: 14px;">
                        <li>Dental Care Specialist</li>
                        <li>Cardiovascular Clinic</li>
                        <li>Dermatology & Skin Science</li>
                        <li>Pediatric Healthcare</li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5 class="text-uppercase fw-bold text-teal mb-3" style="font-size: 12px; color: #2dd4bf; letter-spacing: 1px;">Emergency HQ Desk</h5>
                    <ul class="list-unstyled d-flex flex-column gap-2 text-slate-450" style="font-size: 14px;">
                        <li><i class="bi bi-telephone text-teal me-2" style="color: #0d9488;"></i>+1 (555) HEALTH-911</li>
                        <li><i class="bi bi-envelope text-teal me-2" style="color: #0d9488;"></i>support@smartclinic.com</li>
                        <li><i class="bi bi-map text-teal me-2" style="color: #0d9488;"></i>77 Baker St, Marylebone, London</li>
                    </ul>
                </div>
            </div>
            <div class="border-top border-secondary mt-5 pt-4 d-flex flex-column flex-md-row align-items-center justify-content-between">
                <p class="mb-0" style="font-size: 12px;">&copy; @DateTime.Now.Year SmartClinic Management. All rights reserved. UK licensed outpatient precinct.</p>
                <div class="text-muted d-flex align-items-center gap-1 mt-2 mt-md-0" style="font-size: 12px;">
                    Built using .NET 8, ASP.NET Core MVC, and Bootstrap 5.
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap 5 JavaScript with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
