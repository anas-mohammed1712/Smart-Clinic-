@{
    ViewData["Title"] = "Password Restoration";
}

<div class="row justify-content-center py-5 text-start">
    <div class="col-md-5">
        <div class="card border rounded-5 shadow-lg p-5 bg-white" style="border-radius: 30px;">
            
            <div class="text-center mb-4">
                <div class="bg-teal text-white p-3 d-inline-block rounded-4 mb-3" style="background-color: #0d9488;">
                    <i class="bi bi-key-fill fs-3"></i>
                </div>
                <h3 class="fw-bold tracking-tight text-dark mb-1">Recover Credentials</h3>
                <p class="text-muted" style="font-size: 13px;">Specify your active registry email to dispatch the verification parameters</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger rounded-3" style="font-size: 13px;">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            @if (ViewBag.SuccessMessage != null)
            {
                <div class="alert alert-success rounded-3 text-sm" style="font-size: 13px;">
                    @ViewBag.SuccessMessage
                </div>
            }

            <form asp-action="ForgotPassword" method="post">
                <div class="mb-4">
                    <label class="form-label fw-semibold text-secondary" style="font-size: 12px;">Primary Email Address *</label>
                    <input type="email" name="email" required class="form-control rounded-3 p-3 text-sm" placeholder="e.g. admin@smartclinic.com" style="font-size: 14px;" />
                </div>

                <button type="submit" class="btn btn-teal w-full p-3 mb-3" style="background-color: #0d9488; width: 100%; font-size: 14px;">Trigger Password Recovery</button>
            </form>

            <div class="text-center mt-3" style="font-size: 13px;">
                <a href="@Url.Action("Login", "Account")" class="text-decoration-none text-teal fw-bold" style="color: #0d9488;">Back to Login Platform</a>
            </div>

        </div>
    </div>
</div>
