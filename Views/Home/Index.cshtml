@{
    ViewData["Title"] = "Intelligent Clinic Workstation";
}

<section class="py-5 text-start">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <span class="text-uppercase fw-extrabold tracking-widest text-teal d-inline-block bg-teal-subtle px-3 py-1.5 rounded-pill mb-3" style="color: #0d9488; background-color: #f0fdfa; font-size: 11px;">
                State-of-the-Art Care Platform
            </span>
            <h1 class="display-4 fw-black tracking-tight text-dark mb-4">
                Personalized Care, <br><span class="text-teal" style="color: #0d9488;">Intelligently Orchestrated.</span>
            </h1>
            <p class="lead text-secondary mb-5" style="font-size: 16px; line-height: 1.8;">
                Welcome to SmartClinic. We bridge modern diagnostics, real-time appointments validation, and role-based specialists (Dental, Dermatology, Pediatrics, Cardiology) into a single, seamless, high-contrast workstation.
            </p>
            <div class="d-flex flex-wrap gap-3">
                <a href="@Url.Action("Register", "Account")" class="btn btn-teal px-4 py-3" style="font-size: 14px;">Secure Your Intake Profile</a>
                <a href="#specialties" class="btn btn-outline-secondary px-4 py-3 rounded-4" style="font-size: 14px; border-radius: 12px;">Browse Specialists</a>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="position-relative">
                <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&q=80&w=600" class="img-fluid rounded-5 shadow-lg max-w-100" style="border-radius: 30px;" alt="Smart Clinic Workspace" />
                <div class="position-absolute bottom-0 start-0 translate-middle-y bg-white p-4 rounded-4 shadow border border-light ms-4 d-none d-sm-block" style="border-radius: 20px;">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-teal-subtle text-teal p-3 rounded-3" style="background-color: #f0fdfa; color: #0d9488;">
                            <i class="bi bi-clock-fill fs-4"></i>
                        </div>
                        <div>
                            <span class="d-block fw-bold text-dark text-start" style="font-size: 15px;">Fast Track Intake</span>
                            <span class="text-muted text-start d-block" style="font-size: 11px;">Within 5 Minutes of Arrival</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Specialties section -->
<section id="specialties" class="py-5 my-5">
    <div class="text-center mb-5 max-w-2xl mx-auto">
        <h2 class="fw-bold tracking-tight text-dark">Clinical Care Specialties</h2>
        <p class="text-secondary mt-2">Comprehensive diagnostics and healing systems mapped across major specialist divisions.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-3 text-start">
            <div class="card h-100 border-0 shadow-sm p-4 rounded-4 bg-white">
                <div class="text-teal mb-3" style="color: #0d4080;"><i class="bi bi-heart-pulse-fill fs-3 text-danger"></i></div>
                <h5 class="fw-bold">Cardiology</h5>
                <p class="text-muted" style="font-size: 13px; line-height: 1.6;">Advanced electrocardiogram checks, myocardial diagnostics, and preventative consultations.</p>
            </div>
        </div>
        <div class="col-md-3 text-start">
            <div class="card h-100 border-0 shadow-sm p-4 rounded-4 bg-white">
                <div class="text-teal mb-3" style="color: #0ea5e9;"><i class="bi bi-emoji-smile-fill fs-3 text-info"></i></div>
                <h5 class="fw-bold">Dental Care</h5>
                <p class="text-muted" style="font-size: 13px; line-height: 1.6;">Dental extraction, composite restoration, and aesthetic root-canal treatments.</p>
            </div>
        </div>
        <div class="col-md-3 text-start">
            <div class="card h-100 border-0 shadow-sm p-4 rounded-4 bg-white">
                <div class="text-teal mb-3" style="color: #eab308;"><i class="bi bi-shield-fill-plus fs-3 text-warning"></i></div>
                <h5 class="fw-bold">Dermatology</h5>
                <p class="text-muted" style="font-size: 13px; line-height: 1.6;">Skin barrier restoration therapy, eczema consultations, biopsies, and moles evaluation.</p>
            </div>
        </div>
        <div class="col-md-3 text-start">
            <div class="card h-100 border-0 shadow-sm p-4 rounded-4 bg-white">
                <div class="text-teal mb-3" style="color: #8b5cf6;"><i class="bi bi-people-fill fs-3 text-primary"></i></div>
                <h5 class="fw-bold">Pediatrics</h5>
                <p class="text-muted" style="font-size: 13px; line-height: 1.6;">Dedicated outpatient assessments for child health growth track indexes, and immunizations.</p>
            </div>
        </div>
    </div>
</section>

<!-- Active Specialists list from database -->
<section class="py-5 my-5 text-start">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center border-bottom pb-4 mb-4 gap-3">
        <div>
            <h3 class="fw-bold text-dark mb-1">Our Board-Certified Medical Board</h3>
            <p class="text-muted mb-0" style="font-size: 14px;">Review certified clinicians currently available on outpatient consult schedules.</p>
        </div>
        <a href="@Url.Action("Login", "Account")" class="btn btn-teal">Log In to Schedule</a>
    </div>

    <div class="row g-4">
        @if (ViewBag.Doctors != null)
        {
            foreach (var doc in (List<SmartClinicManagementSystem.Models.Doctor>)ViewBag.Doctors)
            {
                <div class="col-md-4">
                    <div class="card border shadow-sm p-4 h-100 rounded-4 bg-white">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <img src="@doc.ProfileImage" class="rounded-3 object-fit-cover" style="width: 50px; height: 50px;" alt="@doc.FullName" />
                            <div>
                                <h5 class="fw-bold mb-0 text-dark" style="font-size: 16px;">@doc.FullName</h5>
                                <span class="badge text-teal-700 bg-teal-subtle text-uppercase fw-bold" style="font-size: 9px; color: #0d9488; background-color: #f0fdfa;">@doc.Specialty</span>
                            </div>
                        </div>
                        <p class="text-secondary" style="font-size: 13px; line-height: 1.6;">@doc.Bio</p>
                        <div class="mt-auto border-top pt-3 d-flex align-items-center justify-content-between" style="font-size: 12px;">
                            <span class="text-muted"><i class="bi bi-calendar-event me-1"></i>Experience: @doc.Experience</span>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</section>
